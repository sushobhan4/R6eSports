# Local setup:
# 1. Copy this file to .env.
# 2. Fill in your Supabase project URL and service role key.
# 3. Run `npm start` and open http://localhost:4173.

# Render setup:
# Add SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in the Render service Environment tab.
# Render provides PORT automatically, so you normally do not set PORT there.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional local port. Render overrides this with process.env.PORT.
PORT=4173
